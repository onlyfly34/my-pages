---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getAllTags } from '../../utils/posts';
import { tagPath } from '../../utils/path';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="文章" description="全部技術筆記列表">
  <section class="container wrap">
    <header class="page-head">
      <h1>文章</h1>
      <p class="muted">目前共 {posts.length} 篇。</p>
    </header>

    {
      tags.length > 0 && (
        <ul class="tag-list tags-row">
          {tags.map(({ tag, count }) => (
            <li>
              <a class="tag" href={tagPath(tag)}>
                #{tag} <span class="count">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <div class="post-list">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: var(--content-width);
    margin-inline: auto;
  }
  .page-head {
    padding-top: var(--space-8);
    padding-bottom: var(--space-3);
  }
  .page-head h1 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-2);
  }
  .tags-row {
    margin-bottom: var(--space-4);
  }
  .count {
    color: var(--text-muted);
    font-size: 0.85em;
  }
</style>
