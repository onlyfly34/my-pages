---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts, getAllTags } from '../utils/posts';
import { SITE } from '../config/site';
import { tagPath } from '../utils/path';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title={SITE.title}>
  <section class="container hero">
    <h1>{SITE.title}</h1>
    <p class="lead muted">{SITE.description}</p>
  </section>

  <section class="container list">
    {
      tags.length > 0 && (
        <ul class="tag-list tags-row">
          {tags.map(({ tag, count }) => (
            <li>
              <a class="tag" href={tagPath(tag)}>
                #{tag} <span class="count">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }

    {
      posts.length === 0 ? (
        <p class="muted">
          還沒有文章。在 <code>src/content/posts/</code> 新增一個 <code>.mdx</code> 就會出現在這裡。
        </p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: var(--content-width);
    margin-inline: auto;
    padding-top: var(--space-10);
    padding-bottom: var(--space-4);
  }
  .hero h1 {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-3);
    letter-spacing: -0.02em;
  }
  .lead {
    font-size: var(--text-lg);
    margin: 0;
    max-width: 42ch;
  }
  .list {
    max-width: var(--content-width);
    margin-inline: auto;
  }
  .tags-row {
    margin-bottom: var(--space-2);
  }
  .count {
    color: var(--text-muted);
    font-size: 0.85em;
  }
</style>
